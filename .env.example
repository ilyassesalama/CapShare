# Copy to .env and fill in to build a signed + notarized macOS app locally.
# electron-builder auto-loads .env from the project root.
#
# Signing uses your Developer ID Application cert from the login keychain
# (auto-discovery). Notarization uses these Apple ID credentials:
APPLE_ID=you@example.com
# App-specific password from https://appleid.apple.com (NOT your account password).
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Developer Team ID (Apple Developer account → Membership).
APPLE_TEAM_ID=XXXXXXXXXX
